theme = Solarized Dark Patched
font-family = Lilex Nerd Font Mono
font-size = 14
cursor-style = block
cursor-style-blink = false
app-notifications = no-clipboard-copy
window-width = 110
window-height = 30
command = tmux
window-padding-balance = true
window-padding-y = 0
window-padding-x = 0

background = #031319
background-opacity = 0.9
